# BeaconHaus Copilot - Google Gemini API key.
# Server-side only: this key is read in the /api/copilot route and never reaches the browser.
# Get one at https://aistudio.google.com  ("Get API key").
# Copy this file to .env.local and fill in the value, then restart the dev server.
GEMINI_API_KEY=

# Optional model overrides (defaults shown). Override only if Google renames a model.
# GEMINI_MODEL_PRO=gemini-2.5-pro
# GEMINI_MODEL_FLASH=gemini-2.5-flash
# GEMINI_MODEL_LITE=gemini-2.5-flash-lite
